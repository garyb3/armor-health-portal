generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  APPLICANT
  RECRUITER
  ADMIN_ASSISTANT
  COUNTY_REPRESENTATIVE
  HR
  ADMIN
}

enum FormType {
  VOLUNTEER_APP
  PROFESSIONAL_LICENSE
  DRUG_SCREEN
  BACKGROUND_CHECK
  WEB_CHECK
}

enum FormStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PENDING_REVIEW
  APPROVED
  DENIED
}

model Applicant {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String
  firstName       String
  lastName        String
  role            Role
  approved          Boolean          @default(false)
  emailVerified     Boolean          @default(false)
  verificationToken    String?          @unique
  resetToken           String?          @unique
  resetTokenExpiresAt  DateTime?
  tokenVersion         Int              @default(0)
  phone             String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  formSubmissions FormSubmission[]
  sensitiveData   SensitiveData?

  @@map("applicants")
}

model FormSubmission {
  id          String     @id @default(cuid())
  applicantId String
  formType    FormType
  status      FormStatus @default(NOT_STARTED)
  formData    Json?
  receiptFile String?
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewNote   String?
  submittedAt      DateTime?
  statusChangedAt  DateTime   @default(now())
  lastAlertSentAt  DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([applicantId, formType])
  @@map("form_submissions")
}

model Invite {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  role      Role
  used      Boolean  @default(false)
  expiresAt DateTime
  createdBy String
  createdAt DateTime @default(now())

  @@map("invites")
}

model SensitiveData {
  id           String   @id @default(cuid())
  applicantId  String   @unique
  encryptedSsn String
  ssnLastFour  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("sensitive_data")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  targetId  String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([targetId])
  @@index([action])
  @@map("audit_logs")
}
