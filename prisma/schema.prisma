generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  HR
  ADMIN
  COUNTY_REP
}

enum FormType {
  VOLUNTEER_APP
  PROFESSIONAL_LICENSE
  DRUG_SCREEN
  BACKGROUND_CHECK
}

enum FormStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PENDING_REVIEW
  APPROVED
  DENIED
}

model Applicant {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String
  firstName       String
  lastName        String
  role            Role?
  approved          Boolean          @default(false)
  denied            Boolean          @default(false)
  emailVerified     Boolean          @default(false)
  verificationToken    String?          @unique
  resetToken           String?          @unique
  resetTokenExpiresAt  DateTime?
  tokenVersion         Int              @default(0)
  phone             String?
  offerAcceptedAt   DateTime?
  archivedAt        DateTime?
  archivedBy        String?
  notes             String?
  countyId          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  formSubmissions FormSubmission[]
  sensitiveData   SensitiveData?
  candidateNotes  Note[]
  county          County?          @relation(fields: [countyId], references: [id])
  userCounties    UserCounty[]

  @@index([denied])
  @@index([role])
  @@index([approved])
  @@index([emailVerified])
  @@index([role, approved])
  @@index([role, denied])
  @@index([archivedAt])
  @@index([countyId])
  @@map("applicants")
}

model FormSubmission {
  id          String     @id @default(cuid())
  applicantId String
  countyId    String
  formType    FormType
  status      FormStatus @default(NOT_STARTED)
  formData    Json?
  receiptFile String?
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewNote   String?
  submittedAt      DateTime?
  statusChangedAt  DateTime   @default(now())
  lastAlertSentAt  DateTime?
  stepStartedAt    DateTime?
  stepCompletedAt  DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  county    County    @relation(fields: [countyId], references: [id])

  @@unique([applicantId, formType])
  @@index([applicantId])
  @@index([status])
  @@index([applicantId, status])
  @@index([status, statusChangedAt])
  @@index([applicantId, createdAt])
  @@index([countyId, status])
  @@map("form_submissions")
}

model Invite {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  role      Role
  used      Boolean  @default(false)
  expiresAt DateTime
  createdBy String
  countyId  String
  createdAt DateTime @default(now())

  county County @relation(fields: [countyId], references: [id])

  @@index([email, used, expiresAt])
  @@index([countyId])
  @@map("invites")
}

model SensitiveData {
  id           String   @id @default(cuid())
  applicantId  String   @unique
  encryptedSsn String
  ssnLastFour  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("sensitive_data")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  targetId  String
  metadata  Json?
  ipAddress String?
  countyId  String?
  createdAt DateTime @default(now())

  county County? @relation(fields: [countyId], references: [id])

  @@index([userId])
  @@index([targetId])
  @@index([action])
  @@index([userId, action, createdAt])
  @@index([countyId, createdAt])
  @@map("audit_logs")
}

model Note {
  id          String   @id @default(cuid())
  content     String
  authorId    String
  authorName  String
  applicantId String
  countyId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  comments  NoteComment[]
  county    County @relation(fields: [countyId], references: [id])

  @@index([applicantId, createdAt])
  @@index([authorId])
  @@index([countyId])
  @@map("notes")
}

model NoteComment {
  id         String   @id @default(cuid())
  content    String
  authorId   String
  authorName String
  noteId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt])
  @@index([authorId])
  @@map("note_comments")
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  keyPrefix  String
  role       Role      @default(HR)
  scopes     String    @default("read")
  active     Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdBy  String
  countyId   String?
  createdAt  DateTime  @default(now())

  @@map("api_keys")
}

model County {
  id          String   @id @default(cuid())
  slug        String   @unique
  displayName String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  applicants      Applicant[]
  formSubmissions FormSubmission[]
  invites         Invite[]
  notes           Note[]
  auditLogs       AuditLog[]
  userCounties    UserCounty[]

  @@map("counties")
}

model UserCounty {
  id          String   @id @default(cuid())
  applicantId String
  countyId    String
  createdAt   DateTime @default(now())

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  county    County    @relation(fields: [countyId], references: [id], onDelete: Cascade)

  @@unique([applicantId, countyId])
  @@index([applicantId])
  @@index([countyId])
  @@map("user_counties")
}
